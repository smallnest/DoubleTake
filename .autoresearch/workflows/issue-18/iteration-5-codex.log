		for _, conn := range conns {
			...
		}
		// After DESC, TURN for next speaker
		if si < len(speakers)-1 {
			for _, conn := range conns {
				msg := readMsgFromConn(t, conn)
				if msg.Type != game.MsgTurn {
					t.Fatalf(...)
				}   // closes if
			}       // closes for
		}           // closes if si
	}               // closes for si
}                   // closes func
```

